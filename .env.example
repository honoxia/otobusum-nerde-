# Google Maps API Key (required for Android builds)
# Get your key from: https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Flespi MQTT Configuration
FLESPI_TOKEN=your_flespi_token_here
FLESPI_CHANNEL_ID=your_channel_id_here

# Nimbus API (optional - for scheduled arrivals)
NIMBUS_LOCATOR_HASH=your_nimbus_hash_here
