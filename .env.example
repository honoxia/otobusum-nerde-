# Harita: osm (varsayilan) veya google
EXPO_PUBLIC_MAP_PROVIDER=osm

# Google Maps (sadece EXPO_PUBLIC_MAP_PROVIDER=google ise gerekli)
# https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Nimbus locator hash (EAS build icin; bos birakilirsa varsayilan kullanilir)
NIMBUS_LOCATOR_HASH=

# Opsiyonel tram locator hash
EXPO_PUBLIC_TRAM_NIMBUS_LOCATOR_HASH=

# Flespi token uygulama icine gomulmez; runtime'da Nimbus locator sayfasindan cekilir.
# Asagidaki alanlar yalnizca alternatif MQTT modu icin (genelde bos birakilir):
FLESPI_CHANNEL_ID=
FLESPI_DEVICE_IDS=
